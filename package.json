{
  "name": "stashmatic-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Root workspace scripts for Stashmatic",
  "scripts": {
    "dev:api": ".\\api\\.venv\\Scripts\\python -m uvicorn api.main:app --reload --port 8001 --env-file api/.env",
    "dev:web": "npm run dev --prefix web",
    "db:migrate": ".\\api\\.venv\\Scripts\\alembic -c api/alembic.ini upgrade head",
    "db:makemigrations": ".\\api\\.venv\\Scripts\\alembic -c api/alembic.ini revision --autogenerate -m",
    "db:seed": ".\\api\\.venv\\Scripts\\python internal/seed_db.py",
    "types:generate": "npm run gen-types --prefix web"
  }
}